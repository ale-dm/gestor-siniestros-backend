# Copiar este archivo como .env y rellenar los valores reales
# El .env NUNCA debe subirse a git

# ── Local ─────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/siniestros_db
DB_USER=siniestros_user
DB_PASSWORD=siniestros123
JWT_SECRET=unaClaveLargaDeAlMenos32CaracteresParaHS256queDebeCambiarseEnProd
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ── Railway (configurar en el dashboard) ──
# DB_URL=    → copiar de Railway PostgreSQL → Connect → JDBC URL
# DB_USER=   → usuario de Railway PostgreSQL
# DB_PASSWORD= → contraseña de Railway PostgreSQL
# JWT_SECRET= → cadena aleatoria larga y segura
# CORS_ALLOWED_ORIGINS= → URL de Vercel, ej: https://gestor-siniestros.vercel.app
# SPRING_PROFILES_ACTIVE=prod

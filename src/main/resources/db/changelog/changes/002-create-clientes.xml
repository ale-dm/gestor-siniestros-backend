<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-clientes" author="portfolio">
        <createTable tableName="clientes">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="apellidos" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="dni" type="VARCHAR(20)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(150)"/>
            <column name="telefono" type="VARCHAR(20)"/>
            <column name="direccion" type="VARCHAR(255)"/>
            <column name="activo" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="clientes" indexName="idx_clientes_apellidos">
            <column name="apellidos"/>
        </createIndex>
        <createIndex tableName="clientes" indexName="idx_clientes_activo">
            <column name="activo"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
